<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Delete Notes - Notes App</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              background: '#0F172A',
              sidebar: '#1E293B',
              card: '#334155',
              primary: '#6366F1',
              secondary: '#22D3EE',
              textPrimary: '#F1F5F9',
              textSecondary: '#94A3B8',
              borderSubtle: '#475569',
              danger: '#EF4444',
              success: '#22C55E'
            }
          }
        }
      };
    </script>
  </head>
  <body class="min-h-screen bg-background text-textPrimary">
    <div class="flex min-h-screen">
      <!-- Sidebar / Navbar -->
       <%-include('partials/sidebar')%>

      <!-- Main Content -->
      <main class="flex-1 bg-background px-4 sm:px-6 lg:px-10 py-6 sm:py-8">
        <div class="max-w-6xl mx-auto">
          <!-- Header -->
          <div class="mb-6 sm:mb-8">
            <div class="flex items-center gap-3 mb-2">
              <div
                class="h-10 w-10 rounded-full bg-danger/20 flex items-center justify-center"
              >
                <span class="text-danger text-xl">🗑️</span>
              </div>
              <h1
                class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-textPrimary"
              >
                Delete Notes
              </h1>
            </div>
            <p class="text-sm sm:text-base text-textSecondary">
              Select notes you want to delete. This action cannot be undone.
            </p>
          </div>

          <% if (notes && notes.length > 0) { %>
          <!-- Bulk Actions -->
          <div
            class="mb-6 p-4 rounded-xl border border-borderSubtle/70 bg-card/40 flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3"
          >
            <div class="flex items-center gap-3">
              <a
                href="/delete?all=1"
                class="px-4 py-2 rounded-lg border border-danger/60 bg-card/40 text-danger hover:bg-danger/10 transition-colors text-sm font-medium"
              >
                Delete All Notes
              </a>
            </div>
          </div>

          <!-- Notes List -->
          <form method="get" action="/delete" class="space-y-3">
            <div id="notesContainer" class="space-y-3">
              <% notes.forEach((note, index) => { %>
              <% const noteId = note._id; %>
              <div
                class="group rounded-xl border border-borderSubtle/70 bg-card/70 p-4 sm:p-5 flex items-start gap-4 hover:border-danger/50 hover:bg-card/90 transition-all"
              >
                <input
                  type="checkbox"
                  name="id"
                  value="<%= noteId %>"
                  class="mt-1 h-5 w-5 rounded border-borderSubtle bg-card text-danger focus:ring-danger focus:ring-offset-0 focus:ring-offset-background cursor-pointer"
                />
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <h3 class="font-semibold text-sm sm:text-base text-textPrimary">
                      <%= note.title || 'Untitled' %>
                    </h3>
                    <span
                      class="rounded-full bg-textSecondary/10 text-textSecondary text-[10px] px-2 py-0.5 font-medium whitespace-nowrap"
                    >
                      #<%= index + 1 %>
                    </span>
                  </div>
                  <p class="text-xs sm:text-sm text-textSecondary line-clamp-2 mb-2">
                    <%= note.body || '' %>
                  </p>
                  <% if (note.tags) { %>
                  <div class="flex flex-wrap gap-1.5 mt-2">
                    <% const tagList = Array.isArray(note.tags) ? note.tags : String(note.tags).split(',').map(t => t.trim()).filter(Boolean); %>
                    <% tagList.forEach(tag => { %>
                    <span class="rounded-full bg-secondary/10 text-secondary text-[10px] px-2 py-0.5 font-medium">#<%= tag %></span>
                    <% }); %>
                  </div>
                  <% } %>
                </div>
                <a
                  href="/delete?id=<%= noteId %>"
                  class="p-2 rounded-lg border border-danger/60 bg-danger/10 text-danger hover:bg-danger/20 transition-colors"
                  title="Delete this note"
                  onclick="return confirm('Are you sure you want to delete this note?');"
                >
                  <span class="text-sm">🗑️</span>
                </a>
              </div>
              <% }); %>
            </div>
            <button
              type="submit"
              class="px-4 py-2 rounded-lg bg-danger text-textPrimary hover:bg-danger/90 transition-colors text-sm font-semibold flex items-center gap-2"
            >
              <span>🗑️</span>
              <span>Delete Selected</span>
            </button>
          </form>
          <% } else { %>
          <!-- Empty State -->
          <div
            class="text-center py-12 sm:py-16 rounded-2xl border border-borderSubtle/50 bg-card/30"
          >
            <div class="max-w-md mx-auto px-4">
              <div
                class="h-16 w-16 mx-auto mb-4 rounded-full bg-card/60 flex items-center justify-center"
              >
                <span class="text-3xl">📝</span>
              </div>
              <h3 class="text-lg font-semibold text-textPrimary mb-2">
                No notes to delete
              </h3>
              <p class="text-sm text-textSecondary mb-6">
                You don't have any notes yet. Create your first note to get started!
              </p>
              <a
                href="/addNotes.ejs"
                class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-textPrimary hover:bg-primary/90 transition-colors"
              >
                <span>+</span>
                <span>Create Your First Note</span>
              </a>
            </div>
          </div>
          <% } %>
        </div>
      </main>
    </div>
  </body>
</html>
