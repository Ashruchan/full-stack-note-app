<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Note - Notes App</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              background: '#0F172A', // Deep Navy
              sidebar: '#1E293B', // Dark Slate
              card: '#334155', // Soft Slate
              primary: '#6366F1', // Indigo
              secondary: '#22D3EE', // Cyan
              textPrimary: '#F1F5F9', // Off White
              textSecondary: '#94A3B8', // Muted Gray
              borderSubtle: '#475569', // Subtle Gray
              danger: '#EF4444', // Soft Red
              success: '#22C55E' // Green
            }
          }
        }
      };
    </script>
  </head>
  <body class="min-h-screen bg-background text-textPrimary">
    <div class="flex min-h-screen">
      <!-- Sidebar / Navbar -->
       <%- include('partials/sidebar') %>

      <!-- Main Content -->
      <main class="flex-1 bg-background px-4 sm:px-6 lg:px-10 py-6 sm:py-8">
        <div class="max-w-4xl mx-auto">
          <!-- Header -->
          <div class="mb-6 sm:mb-8">
            <h1
              class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-textPrimary mb-2"
            >
              Create New Note
            </h1>
            <p class="text-sm sm:text-base text-textSecondary">
              Write down your thoughts, ideas, or important information. Add tags to organize
              and find your notes easily.
            </p>
          </div>

          <!-- Form -->
          <form
            id="noteForm"
            class="space-y-6"
            method="post"
            action="/notes"
          >
            <!-- Title Input -->
            <div class="space-y-2">
              <label
                for="noteTitle"
                class="block text-sm font-semibold text-textPrimary"
              >
                Note Title <span class="text-danger">*</span>
              </label>
              <input
                type="text"
                id="noteTitle"
                name="title"
                required
                placeholder="Enter a descriptive title for your note..."
                class="w-full rounded-xl border border-borderSubtle/70 bg-card/60 px-4 py-3 text-sm sm:text-base text-textPrimary placeholder:text-textSecondary/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 transition-colors"
              />
            </div>

            <!-- Body Textarea -->
            <div class="space-y-2">
              <label
                for="noteBody"
                class="block text-sm font-semibold text-textPrimary"
              >
                Note Body <span class="text-danger">*</span>
              </label>
              <textarea
                id="noteBody"
                name="body"
                required
                rows="12"
                placeholder="Start writing your note here... You can write as much as you need. This is your space to capture thoughts, ideas, reminders, or any information you want to remember."
                class="w-full rounded-xl border border-borderSubtle/70 bg-card/60 px-4 py-3 text-sm sm:text-base text-textPrimary placeholder:text-textSecondary/60 focus:border-secondary focus:outline-none focus:ring-2 focus:ring-secondary/30 transition-colors resize-y min-h-[200px]"
              ></textarea>
            </div>

            <!-- Tags Section -->
            <div class="space-y-2">
              <label
                for="tags"
                class="block text-sm font-semibold text-textPrimary"
              >
                Tags
                <span class="text-xs font-normal text-textSecondary ml-2"
                  >(comma-separated)</span
                >
              </label>
              <input
                type="text"
                id="tags"
                name="tags"
                placeholder="e.g. work, ideas, personal"
                class="w-full rounded-xl border border-borderSubtle/70 bg-card/60 px-4 py-2 text-sm text-textPrimary placeholder:text-textSecondary/60 focus:border-secondary focus:outline-none focus:ring-2 focus:ring-secondary/30 transition-colors"
              />
            </div>

            <!-- Action Buttons -->
            <div
              class="flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3 pt-4 border-t border-borderSubtle/50"
            >
              <div class="flex items-center gap-2 text-xs text-textSecondary">
                <span class="inline-flex h-2 w-2 rounded-full bg-success"></span>
                <span>Auto-save enabled</span>
              </div>

              <div class="flex items-center gap-3">
                <a
                  href="/"
                  class="px-4 sm:px-6 py-2 rounded-lg border border-borderSubtle bg-card/40 text-textSecondary hover:bg-card hover:border-primary/60 hover:text-textPrimary transition-colors text-sm font-medium"
                >
                  Cancel
                </a>
                <button
                  type="submit"
                  class="px-4 sm:px-6 py-2 rounded-lg bg-primary text-textPrimary hover:bg-primary/90 shadow-md shadow-primary/30 transition-colors text-sm font-semibold flex items-center gap-2"
                >
                  <span>Save Note</span>
                  <span class="text-xs">✓</span>
                </button>
              </div>
            </div>
          </form>
        </div>
      </main>
    </div>
  </body>
</html>
